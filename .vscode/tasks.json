{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "openPgpCommitMsg",
      "type": "promptString",
      "description": "Mensagem do commit (ex.: docs: …; chore: …)",
      "default": "docs: "
    }
  ],
  "tasks": [
    {
      "label": "OpenPGP: commit e push (main)",
      "type": "shell",
      "command": "git add -A && git commit -m \"${input:openPgpCommitMsg}\" && git push origin main",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
